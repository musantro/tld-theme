{{!< default}}

<div class="gh-outer">
    <div class="gh-inner">
        {{#author}}
            <section class="gh-archive">
                <header class="gh-archive-header">
                    {{#if profile_image}}
                        <img class="gh-archive-author-image" src="{{img_url profile_image size="s"}}" alt="{{name}}">
                    {{/if}}
                    <h1 class="gh-archive-name">{{name}}</h1>
                    {{#if bio}}
                        <p class="gh-archive-description">{{bio}}</p>
                    {{/if}}
                </header>
            </section>
        {{/author}}

        <div class="gh-feed">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>

        {{pagination}}
    </div>
</div>
